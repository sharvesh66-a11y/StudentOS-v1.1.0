# =====================================================================
# StudentOS — Environment Variables (TEMPLATE)
# =====================================================================
#
# Copy this file to `.env.local` and fill in real values from your
# Firebase project console: https://console.firebase.google.com
#
# NEVER commit `.env.local` — it is already in .gitignore.
#
# All NEXT_PUBLIC_* vars are exposed to the browser. They are safe to
# expose because Firebase security is enforced by Firestore/Storage rules,
# NOT by hiding these keys.
#
# Server-only vars (no NEXT_PUBLIC_ prefix) must NEVER be imported from
# client code. They are guarded by the `server-only` package.
# =====================================================================

# ---------------------------------------------------------------------
# Firebase Client SDK (safe to expose — protected by security rules)
# ---------------------------------------------------------------------
# Project Settings → General → "Your apps" → SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only set if Google Analytics is enabled in the Firebase console
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------------------------------------------------------------------
# Firebase Emulator (local dev only — set to true to use emulators)
# ---------------------------------------------------------------------
# NEXT_PUBLIC_USE_FIREBASE_EMULATOR=false
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_PORT=9099
# NEXT_PUBLIC_FIREBASE_FIRESTORE_EMULATOR_PORT=8080
# NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_PORT=9199

# ---------------------------------------------------------------------
# Firebase Admin SDK (server-only — NEVER prefix with NEXT_PUBLIC_)
# ---------------------------------------------------------------------
# Project Settings → Service Accounts → generate new private key (JSON)
# Copy the `client_email` and `private_key` fields below.
# The private_key must include the BEGIN/END markers and \n escapes.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------
# Feature flags (optional)
# ---------------------------------------------------------------------
# NOTE: As of Sprint 13.0, feature flags in `src/lib/config.ts` are
# hardcoded constants (all default to `false`) and are NOT read from
# env vars. The vars below are reserved for a future wiring change.
# Uncomment to override the defaults once `config.ts` is updated to
# consume them.
#
# NEXT_PUBLIC_FEATURE_AUTH_ENABLED=false
# NEXT_PUBLIC_FEATURE_DASHBOARD_ENABLED=false
# NEXT_PUBLIC_FEATURE_JUNOVA_AI_ENABLED=false
# NEXT_PUBLIC_FEATURE_PLANNER_ENABLED=false
# NEXT_PUBLIC_FEATURE_NOTES_ENABLED=false
# NEXT_PUBLIC_FEATURE_EXAM_ENABLED=false
# NEXT_PUBLIC_FEATURE_GAMIFICATION_ENABLED=false
# NEXT_PUBLIC_FEATURE_SETTINGS_ENABLED=false
